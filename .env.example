# ── Database ─────────────────────────────────────────────────────────────────
# SQLite default (no setup needed). Swap to postgres:// for production.
DATABASE_URL=sqlite+aiosqlite:///./video_agent.db

# ── LLM provider ─────────────────────────────────────────────────────────────
# Which provider to use: openai | anthropic | deepseek | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Vision-capable model for QA (can be same or different provider)
VISION_PROVIDER=anthropic
VISION_MODEL=claude-sonnet-4-6

# ── TTS provider ─────────────────────────────────────────────────────────────
# edge (free, default) | azure (paid)
TTS_PROVIDER=edge
TTS_VOICE=vi-VN-HoaiMyNeural   # Vietnamese female

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ── Sandbox ───────────────────────────────────────────────────────────────────
# docker (production) | local (dev, no Docker required, UNSAFE)
SANDBOX_MODE=local
SANDBOX_TIMEOUT=90
SANDBOX_DOCKER_IMAGE=manim-sandbox

# ── Storage ───────────────────────────────────────────────────────────────────
ARTIFACT_DIR=./artifacts   # local fs; swap to s3:// for cloud

# ── Stock provider (optional) ─────────────────────────────────────────────────
PEXELS_API_KEY=

# ── Celery / Redis (job queue for heavy media tasks) ─────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Reddit (market search) ────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=video-agent/0.1
